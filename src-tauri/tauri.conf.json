{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "CloudflareR2 Manager",
  "version": "0.9.10",
  "identifier": "com.r2manager.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:client",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "CloudflareR2 Manager",
        "width": 1200,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "dragDropEnabled": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "",
    "shortDescription": "Cloudflare R2 Manager",
    "longDescription": "A modern Cloudflare R2 storage bucket management tool with visual interface.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/r2-proxy-server"],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./nsis/installer.nsi"
      }
    }
  },
  "plugins": {}
}
